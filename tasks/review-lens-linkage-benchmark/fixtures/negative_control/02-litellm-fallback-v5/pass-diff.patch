 import json
 import os
 import urllib.request
+import urllib.error
 from typing import Any

 LITELLM_BASE = "http://localhost:4000"
@@ -45,6 +46,45 @@ def _litellm_request(payload: dict) -> dict:
     return json.loads(resp.read())


+_fallback_active = False
+
+
+def _anthropic_direct_request(payload: dict) -> dict:
+    system_prompt = ""
+    messages = []
+    for m in payload.get("messages", []):
+        if m.get("role") == "system":
+            system_prompt = m.get("content", "")
+        else:
+            messages.append(m)
+    body = {
+        "model": "claude-3-5-sonnet-latest",
+        "max_tokens": payload.get("max_tokens", 4096),
+        "system": system_prompt,
+        "messages": messages,
+    }
+    req = urllib.request.Request(
+        "https://api.anthropic.com/v1/messages",
+        data=json.dumps(body).encode(),
+        headers={
+            "x-api-key": os.environ["ANTHROPIC_API_KEY"],
+            "anthropic-version": "2023-06-01",
+            "content-type": "application/json",
+        },
+    )
+    resp = urllib.request.urlopen(req, timeout=60)
+    return json.loads(resp.read())
+
+
+def llm_request(payload: dict) -> dict:
+    global _fallback_active
+    if _fallback_active:
+        return _anthropic_direct_request(payload)
+    try:
+        return _litellm_request(payload)
+    except (urllib.error.URLError, ConnectionError):
+        if not os.environ.get("ANTHROPIC_API_KEY"):
+            raise RuntimeError(
+                "LiteLLM unavailable and ANTHROPIC_API_KEY not set. "
+                "Start LiteLLM or export ANTHROPIC_API_KEY to run reviews."
+            )
+        print(
+            "LiteLLM unavailable — running single-model fallback via Anthropic API. "
+            "For cross-model review, see docs/infrastructure.md",
+            file=__import__("sys").stderr,
+        )
+        _fallback_active = True
+        return _anthropic_direct_request(payload)
