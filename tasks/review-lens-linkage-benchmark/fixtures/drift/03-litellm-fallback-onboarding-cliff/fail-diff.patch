+def _anthropic_direct_request(payload: dict) -> dict:
+    """The single-model fallback. Anthropic direct is the canonical path;
+    LiteLLM is the single biggest onboarding cliff and this fallback closes it.
+    """
+    api_key = os.environ["ANTHROPIC_API_KEY"]  # KeyError if absent — see "critical" in docs
+    # Translate OpenAI-format payload to Anthropic Messages format.
+    system_prompt = ""
+    messages = []
+    for m in payload.get("messages", []):
+        if m.get("role") == "system":
+            system_prompt = m.get("content", "")
+        else:
+            messages.append(m)
+    body = {
+        "model": "claude-3-5-sonnet-latest",
+        "max_tokens": payload.get("max_tokens", 4096),
+        "system": system_prompt,
+        "messages": messages,
+    }
+    req = urllib.request.Request(
+        "https://api.anthropic.com/v1/messages",
+        data=json.dumps(body).encode(),
+        headers={
+            "x-api-key": api_key,
+            "anthropic-version": "2023-06-01",
+            "content-type": "application/json",
+        },
+    )
+    resp = urllib.request.urlopen(req, timeout=60)
+    return json.loads(resp.read())
+
+
+def llm_request(payload: dict) -> dict:
+    try:
+        return _litellm_request(payload)
+    except (urllib.error.URLError, ConnectionError):
+        # LiteLLM is down — fall back to Anthropic direct.
+        return _anthropic_direct_request(payload)
+
+
