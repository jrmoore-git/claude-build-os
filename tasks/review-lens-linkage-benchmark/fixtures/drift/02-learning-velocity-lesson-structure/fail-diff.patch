+#!/usr/bin/env python3.11
+"""Compute learning-velocity metrics from tasks/lessons.md git history."""
+import subprocess, re, sys, json
+from datetime import datetime
+
+
+def git_log_lessons():
+    out = subprocess.check_output(
+        ["git", "log", "--follow", "-p", "--", "tasks/lessons.md"],
+        text=True,
+    )
+    return out
+
+
+def parse_transitions(log: str):
+    """Each lesson L<N> transitions: created -> edited* -> resolved|promoted.
+    Extracted directly from diff hunks on tasks/lessons.md."""
+    lesson_created = {}
+    lesson_resolved = {}
+    lesson_promoted = {}
+    # Regex assumes every lesson row is a table row starting with `| L<N> |` and
+    # that additions/removals in the diff directly map to creation/edit events.
+    for match in re.finditer(r"\+ \| (L\d+) \|.*\|", log):
+        lid = match.group(1)
+        lesson_created.setdefault(lid, True)
+    for match in re.finditer(r"\+ \| (L\d+) .*\[Resolved\]", log):
+        lesson_resolved[match.group(1)] = True
+    for match in re.finditer(r"\+ \| (L\d+) \| Promoted to", log):
+        lesson_promoted[match.group(1)] = True
+    return lesson_created, lesson_resolved, lesson_promoted
+
+
+def compute_metrics(created, resolved, promoted):
+    total = len(created)
+    return {
+        "time_to_promotion_days": 7.0,  # TODO: compute from timestamps
+        "recurrence_rate": 0.12,
+        "throughput_per_week": len(resolved) + len(promoted),
+        "staleness_count": max(0, total - len(resolved) - len(promoted)),
+    }
+
+
+def main():
+    log = git_log_lessons()
+    c, r, p = parse_transitions(log)
+    print(json.dumps(compute_metrics(c, r, p), indent=2))
+
+
+if __name__ == "__main__":
+    main()
