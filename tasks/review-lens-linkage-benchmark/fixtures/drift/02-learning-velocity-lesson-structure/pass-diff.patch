+#!/usr/bin/env python3.11
+"""Compute learning-velocity metrics from tasks/lessons.md git history.
+
+Emits only metrics whose underlying transitions can be reliably detected from
+the current `tasks/lessons.md` history format. Metrics that depend on
+consistent status transitions surface as `null` with an accompanying
+`unavailable_reason`, rather than fabricating a value.
+"""
+import subprocess, re, json
+
+
+def git_log_lessons():
+    return subprocess.check_output(
+        ["git", "log", "--follow", "-p", "--", "tasks/lessons.md"],
+        text=True,
+    )
+
+
+def detect_transition_coverage(log: str) -> dict:
+    """Return which transition types are parseable from current history."""
+    return {
+        "created": bool(re.search(r"\+\s*\|\s*L\d+\s*\|", log)),
+        "edited": True,  # any diff line on the file counts
+        "resolved": bool(re.search(r"\[Resolved", log)),
+        "promoted": bool(re.search(r"\| Promoted to", log)),
+    }
+
+
+def compute_metrics(log: str) -> dict:
+    coverage = detect_transition_coverage(log)
+    metrics: dict = {}
+    unavailable: dict[str, str] = {}
+
+    if coverage["created"] and coverage["resolved"]:
+        metrics["throughput_per_week"] = None  # placeholder — real calc from timestamps
+    else:
+        unavailable["throughput_per_week"] = (
+            "lesson creation or resolution transitions not consistently encoded in history"
+        )
+
+    if coverage["created"] and coverage["promoted"]:
+        metrics["time_to_promotion_days"] = None
+    else:
+        unavailable["time_to_promotion_days"] = (
+            "lesson creation or promotion transitions not consistently encoded"
+        )
+
+    metrics["staleness_count"] = None  # TODO: compute from edit timestamps
+    metrics["recurrence_rate"] = None
+
+    return {"metrics": metrics, "unavailable": unavailable, "coverage": coverage}
+
+
+def main():
+    log = git_log_lessons()
+    result = compute_metrics(log)
+    print(json.dumps(result, indent=2))
+    if result["unavailable"]:
+        print(
+            "\nNote: some metrics could not be derived from current lessons.md "
+            "history format. Surfacing as unavailable rather than fabricating values.",
+            flush=True,
+        )
+
+
+if __name__ == "__main__":
+    main()
