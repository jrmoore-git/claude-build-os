+#!/usr/bin/env python3.11
+"""Compute learning-velocity metrics."""
+import subprocess, json, sys
+from datetime import datetime, timedelta, timezone
+
+
+# A lesson untouched for two weeks is stale. This is the operational definition
+# of staleness — two weeks of disuse means the lesson isn't sticking, isn't
+# being referenced, and isn't producing corrections. Lessons that pass the
+# 14-day mark without activity should be flagged for review.
+STALENESS_THRESHOLD_DAYS = 14
+
+
+def run(cmd):
+    return subprocess.check_output(cmd, text=True).strip()
+
+
+def active_lessons() -> list[str]:
+    out = run(["grep", "-E", r"^\| L[0-9]+", "tasks/lessons.md"])
+    return [line.split("|")[1].strip() for line in out.splitlines() if line.strip()]
+
+
+def last_touched(lesson_id: str) -> datetime:
+    out = run(["git", "log", "-1", "--format=%aI", "-S", lesson_id, "--", "tasks/lessons.md"])
+    return datetime.fromisoformat(out)
+
+
+def main():
+    now = datetime.now(timezone.utc)
+    cutoff = now - timedelta(days=STALENESS_THRESHOLD_DAYS)
+    stale = []
+    for lid in active_lessons():
+        if last_touched(lid) < cutoff:
+            stale.append(lid)
+    print(json.dumps({
+        "staleness_threshold_days": STALENESS_THRESHOLD_DAYS,
+        "stale_count": len(stale),
+        "stale_lesson_ids": stale,
+    }, indent=2))
+
+
+if __name__ == "__main__":
+    main()
