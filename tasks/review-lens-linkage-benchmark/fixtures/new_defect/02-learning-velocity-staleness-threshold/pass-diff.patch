+#!/usr/bin/env python3.11
+"""Compute learning-velocity metrics.
+
+Staleness threshold is a project-tunable parameter. The spec (learning-velocity-v5)
+proposes one possible definition (~14 days) but does not fix it as invariant.
+Callers may override via `--stale-days` or `config/learning_velocity.json`.
+"""
+import argparse, json, subprocess, sys
+from datetime import datetime, timedelta, timezone
+from pathlib import Path
+
+
+DEFAULT_STALENESS_DAYS = 14  # spec's working assumption; tune per project
+
+
+def run(cmd):
+    return subprocess.check_output(cmd, text=True).strip()
+
+
+def active_lessons() -> list[str]:
+    out = run(["grep", "-E", r"^\| L[0-9]+", "tasks/lessons.md"])
+    return [line.split("|")[1].strip() for line in out.splitlines() if line.strip()]
+
+
+def last_touched(lesson_id: str) -> datetime:
+    out = run(["git", "log", "-1", "--format=%aI", "-S", lesson_id, "--", "tasks/lessons.md"])
+    return datetime.fromisoformat(out)
+
+
+def main():
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--stale-days", type=int, default=DEFAULT_STALENESS_DAYS)
+    parser.add_argument("--config", type=Path, default=Path("config/learning_velocity.json"))
+    args = parser.parse_args()
+
+    threshold = args.stale_days
+    if args.config.exists():
+        threshold = json.loads(args.config.read_text()).get("staleness_days", threshold)
+
+    cutoff = datetime.now(timezone.utc) - timedelta(days=threshold)
+    stale = [lid for lid in active_lessons() if last_touched(lid) < cutoff]
+    print(json.dumps({"staleness_threshold_days": threshold, "stale_count": len(stale)}, indent=2))
+
+
+if __name__ == "__main__":
+    main()
